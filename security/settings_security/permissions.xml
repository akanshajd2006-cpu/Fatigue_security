<?xml version="1.0" encoding="UTF-8"?>

<dds>
    <permissions>

        <grant name="settings_access">

            <subject_name>
                permission_monitor_node
            </subject_name>

            <validity>
                <not_before>2026-01-01T00:00:00</not_before>
                <not_after>2027-01-01T00:00:00</not_after>
            </validity>

            <allow_rule>
                <domains>
                    <id>0</id>
                </domains>

                <publish>
                    <topics>
                        <topic>/permissions</topic>
                    </topics>
                </publish>

                <subscribe>
                    <topics>
                        <topic>/settings</topic>
                    </topics>
                </subscribe>

            </allow_rule>

        </grant>

    </permissions>
</dds>
